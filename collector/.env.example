# Router connectivity
ROUTER_HOST=192.168.1.1
ROUTER_USERNAME=admin
ROUTER_PASSWORD=your-router-password
ROUTER_USE_SSL=false
# ROUTER_PORT=8443

# Collector behavior
ROUTER_POLL_INTERVAL=3
ROUTER_HISTORY_LIMIT=60
ROUTER_MAX_DEVICE_ROWS=60
ROUTER_USAGE_RETENTION_DAYS=183
ROUTER_USAGE_PERSIST_INTERVAL=20
# ROUTER_USAGE_HISTORY_FILE=collector/data/usage-history.json
# auto = use mock mode when router credentials are missing
ROUTER_MOCK_MODE=auto
COLLECTOR_LOG_LEVEL=INFO

# API server
COLLECTOR_HOST=0.0.0.0
COLLECTOR_PORT=8000
COLLECTOR_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
